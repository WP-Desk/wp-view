    "require": {
        "php": ">=7.1 | ^8"
    },
    "require-dev": {
        "phpunit/phpunit": "^7 | ^8 | ^9",
        "wpdesk/wp-code-sniffer": "^1",
        "mockery/mockery": "^1",
        "10up/wp_mock": "^1"
    },
    "autoload": {
        "psr-4": {"WPDesk\\View\\": "src/"}
    },
